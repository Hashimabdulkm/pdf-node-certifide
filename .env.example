# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret Laravel sends in x-api-key when calling /generate-pdf
PDF_SERVICE_SECRET=195916B41274D01883388B96DFAD6E

# Secret this service sends in x-api-key when POSTing back to Laravel's callback
LARAVEL_CALLBACK_SECRET=your-callback-secret

# ── Tuning ────────────────────────────────────────────────────────────────────
# Max time (ms) Puppeteer waits for the page to render before failing
RENDER_TIMEOUT_MS=90000

# Max request body size accepted by Express
MAX_BODY=5mb
